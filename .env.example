VITE_HA_URL=
VITE_HA_TOKEN=

# Used by the Peak Rate card. The browser must be allowed by CORS.
# Set to "disabled" to skip direct price-feed fetching.
VITE_PEAK_RATE_URL=http://192.168.1.156:1000/

# EVCC solar forecast is preferred because it matches EVCC's own Forecast view.
# Set VITE_EVCC_SOLAR_FORECAST_URL=disabled to use the Open-Meteo fallback below.
VITE_EVCC_URL=http://192.168.1.156:7070
VITE_EVCC_SOLAR_FORECAST_URL=http://192.168.1.156:7070/api/tariff/solar

# Open-Meteo solar forecast fallback for the Overview Solar Forecast card.
VITE_SOLAR_FORECAST_LATITUDE=55.493
VITE_SOLAR_FORECAST_LONGITUDE=10.2046
VITE_SOLAR_FORECAST_TILT=30
VITE_SOLAR_FORECAST_AZIMUTH=0
VITE_SOLAR_PANEL_CAPACITY_KW=10
VITE_SOLAR_FORECAST_TIMEZONE=Europe/Copenhagen

# Used by the Solar Forecast card through Open-Meteo.
VITE_OPEN_METEO_LATITUDE=55.493
VITE_OPEN_METEO_LONGITUDE=10.2046
VITE_OPEN_METEO_TIMEZONE=Europe/Copenhagen
VITE_OPEN_METEO_FORECAST_DAYS=2
VITE_SOLAR_PANEL_TILT_DEGREES=30
VITE_SOLAR_PANEL_AZIMUTH_DEGREES=0
VITE_SOLAR_PANEL_CAPACITY_KW=10

BATTERY_OPTIMIZER_PORT=8090

# Home Assistant live entities for "now" values
BATTERY_OPTIMIZER_HA_URL=http://192.168.1.156:30103
BATTERY_OPTIMIZER_HA_TOKEN=
BATTERY_OPTIMIZER_BATTERY_SOC_ENTITY=sensor.foxess_battery_soc
BATTERY_OPTIMIZER_BATTERY_POWER_ENTITY=sensor.foxess_battery_power
BATTERY_OPTIMIZER_GRID_POWER_ENTITY=sensor.foxess_grid_power
BATTERY_OPTIMIZER_HOME_POWER_ENTITY=sensor.foxess_load_power
BATTERY_OPTIMIZER_SOLAR_POWER_ENTITY=sensor.evcc_pv_power

# Hourly price windows
BATTERY_OPTIMIZER_PRICE_URL=http://192.168.1.156:1000/

# Solar forecast windows
BATTERY_OPTIMIZER_SOLAR_FORECAST_URL=http://192.168.1.156:7070/api/tariff/solar

# Optimizer tuning
BATTERY_OPTIMIZER_BUY_ADDON_DKK=0.42
BATTERY_OPTIMIZER_SELL_DEDUCTION_DKK=0.16

# Optional custom persistence path
# BATTERY_OPTIMIZER_STATE_PATH=/path/to/battery-optimizer-state.json
